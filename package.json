{
  "name": "web3-ccvar-com",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api": "go run ./cmd/ccvar-quant",
    "dev": "vite --host 127.0.0.1",
    "dev:full": "npm run api",
    "build": "vite build",
    "build:app": "npm run build && go build -o bin/ccvar-quant ./cmd/ccvar-quant",
    "package:desktop": "bash scripts/package-desktop.sh",
    "package:native:macos": "bash scripts/package-native-macos.sh",
    "package:native:windows": "pwsh -File scripts/package-native-windows.ps1",
    "smoke:local": "bash scripts/smoke-local.sh",
    "acceptance:env": "bash scripts/check-acceptance-env.sh",
    "acceptance:live": "bash scripts/acceptance-live.sh",
    "audit:final": "bash scripts/final-audit.sh",
    "audit:complete": "bash scripts/assert-final-complete.sh",
    "verify:release": "bash scripts/verify-release.sh",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@vitejs/plugin-react": "5.0.4",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.21.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "vite": "6.4.2"
  }
}
